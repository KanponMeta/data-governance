# Platform
PLATFORM_HTTP_ADDR=:8080
PLATFORM_LOG_LEVEL=info

# Database
DATABASE_URL=postgres://platform:platform@postgres:5432/platform?sslmode=disable

# JWT
JWT_SIGNING_KEY=replace-with-base64-encoded-32-byte-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Admin bootstrap (used only on first start)
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=replace-on-first-start
